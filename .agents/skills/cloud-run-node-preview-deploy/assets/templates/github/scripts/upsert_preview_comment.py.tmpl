#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import sys
import urllib.error
import urllib.request


API_ROOT = "https://api.github.com"
MARKER = "<!-- cloud-run-preview-deploy -->"


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Create or update the Cloud Run preview comment on a pull request."
    )
    parser.add_argument("--repo", required=True, help="owner/repo")
    parser.add_argument("--issue-number", required=True, type=int)
    parser.add_argument("--service", required=True)
    parser.add_argument("--region", required=True)
    parser.add_argument("--url", required=True)
    return parser.parse_args()


def github_request(token: str, method: str, path: str, payload: dict | None = None) -> object:
    body = None
    headers = {
        "Accept": "application/vnd.github+json",
        "Authorization": f"Bearer {token}",
        "User-Agent": "cloud-run-preview-comment",
    }
    if payload is not None:
        body = json.dumps(payload).encode("utf-8")
        headers["Content-Type"] = "application/json"

    request = urllib.request.Request(
        f"{API_ROOT}{path}",
        data=body,
        headers=headers,
        method=method,
    )

    try:
        with urllib.request.urlopen(request) as response:
            content = response.read().decode("utf-8")
    except urllib.error.HTTPError as exc:
        message = exc.read().decode("utf-8", errors="replace")
        raise SystemExit(f"GitHub API request failed: {exc.code} {message}") from exc

    if not content:
        return {}
    return json.loads(content)


def render_comment(service: str, region: str, url: str) -> str:
    return (
        f"{MARKER}\n"
        "## Cloud Run Preview\n\n"
        f"- Service: `{service}`\n"
        f"- Region: `{region}`\n"
        f"- URL: {url}\n\n"
        "This comment is updated whenever the preview deployment is refreshed.\n"
    )


def main() -> int:
    args = parse_args()
    token = os.environ.get("GITHUB_TOKEN")
    if not token:
        raise SystemExit("GITHUB_TOKEN is required")

    comments = github_request(
        token,
        "GET",
        f"/repos/{args.repo}/issues/{args.issue_number}/comments?per_page=100",
    )
    if not isinstance(comments, list):
        raise SystemExit("Unexpected GitHub API response while listing comments")

    body = render_comment(args.service, args.region, args.url)
    existing = next((comment for comment in comments if MARKER in comment.get("body", "")), None)

    if existing is None:
        github_request(
            token,
            "POST",
            f"/repos/{args.repo}/issues/{args.issue_number}/comments",
            {"body": body},
        )
        print("Created preview comment")
        return 0

    github_request(
        token,
        "PATCH",
        f"/repos/{args.repo}/issues/comments/{existing['id']}",
        {"body": body},
    )
    print("Updated preview comment")
    return 0


if __name__ == "__main__":
    sys.exit(main())
